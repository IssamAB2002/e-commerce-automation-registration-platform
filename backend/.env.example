# Django
SECRET_KEY=replace-with-a-50-char-random-secret-key
DEBUG=False
ALLOWED_HOSTS=localhost,127.0.0.1,.railway.app

# PostgreSQL
POSTGRES_URL=postgresql://USER:PASSWORD@HOST:PORT/DBNAME

# Redis
REDIS_URL=rediss://default:TOKEN@HOST:PORT

# Facebook / Meta
FB_APP_ID=your-facebook-app-id
FB_APP_SECRET=your-facebook-app-secret
FB_WEBHOOK_VERIFY_TOKEN=choose-a-random-verify-token
FB_REDIRECT_URI=https://your-backend.railway.app/api/auth/facebook/callback/

# n8n (fallback; per-group URLs stored in DB)
N8N_DEFAULT_WEBHOOK=https://your-n8n-instance/webhook/replace_with_real_url

# Gemini (Gemini API for AI product descriptions)
GEMINI_API_KEY=your-gemini-api-key-here

# Frontend URL (CORS + OAuth redirects)
FRONTEND_URL=https://your-frontend-domain.com

# Internal API secret (used by n8n to call /api/internal/ endpoints)
INTERNAL_API_SECRET=replace-with-a-random-32-char-secret

# Email (SMTP for password reset & payment notifications)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-password
EMAIL_USE_TLS=True
DEFAULT_FROM_EMAIL=EcomAuto <no-reply@your-domain.com>
ADMIN_EMAIL=admin@your-domain.com

# Sentry (optional — leave blank to disable)
SENTRY_DSN=

# Email backend (use 'django.core.mail.backends.smtp.EmailBackend' in production)
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
